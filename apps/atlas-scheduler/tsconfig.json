{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@atlas/core": ["../../packages/core/src"],
      "@atlas/event-bus": ["../../packages/event-bus/src"],
      "@atlas/server-common": ["../../packages/server-common/src"]
    }
  },
  "include": ["src"]
}
